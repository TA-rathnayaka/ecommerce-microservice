# ============================================================================
# Copy this to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars
# ============================================================================

location             = "southeastasia"      # az account list-locations -o table
environment_name     = "ecommerce"
resource_group_name  = "rg-ecommerce"
acr_name             = "ecommerceacrXXXXX"  # Must be globally unique, no hyphens
aks_cluster_name     = "aks-ecommerce"
aks_node_count       = 2
aks_node_vm_size     = "Standard_B2s"       # Cheap dev node; use Standard_D2s_v3 for prod
app_secret           = "change_me_in_production"
image_tag            = "latest"
